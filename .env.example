# ── Stacks ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=SP1V72500C63KN9E348QDK9X879MASSTN0J3KBQ5N
NEXT_PUBLIC_CONTRACT_NAME=stacks-quest-v3
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_STACKS_API_URL=https://api.mainnet.hiro.so
NEXT_PUBLIC_BASE_URL=https://stacks-quest-ten.vercel.app

# ── Language model ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── x402 Payments (Base Network) ──────────────────────────────────────────────
PAYMENT_ADDRESS=your_base_evm_address_here
# Facilitator that actually verifies signatures + settles the USDC transfer on-chain.
# Defaults to the public reference facilitator (https://x402.org) if unset — fine for
# testing, but you likely want a production facilitator (e.g. Coinbase CDP) for real
# mainnet traffic. STRICT=true blocks premium tools entirely if the facilitator is down
# instead of degrading to structural-only payment checks.
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_FACILITATOR_API_KEY=
X402_STRICT_FACILITATOR=false

# ── Signing keys (NEVER commit real values) ───────────────────────────────────
STACKS_PRIVATE_KEY=your_stacks_private_key_here
EVM_PRIVATE_KEY=your_evm_private_key_here

# ── RPC overrides (optional — defaults are set in hardhat.config.ts) ──────────
CELO_RPC=https://forno.celo.org
BASE_RPC_URL=https://mainnet.base.org
CELO_RPC_URL=https://forno.celo.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ALFAJORES_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

