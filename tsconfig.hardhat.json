{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "moduleResolution": "node",
    "lib":              ["ES2020"],
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true
  },
  "include": ["hardhat.config.ts", "scripts/**/*", "contracts/test/**/*"]
}
