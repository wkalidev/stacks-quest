    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@hirosystems/clarinet-sdk": "^3.8.1",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "hardhat": "^2.28.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "vitest-environment-clarinet": "^3.0.2"
  }
